DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/integrity_shield
PT_SALT=replace-me-with-a-long-random-secret
PROTECTION_ORDER_SIGNING_KEY=replace-me-with-a-DIFFERENT-long-random-secret
RECOVERY_SALT=replace-me-with-yet-ANOTHER-long-random-secret
# DANGER: enables /admin/demo-setup which wipes the entire data plane.
# Set to 1 only on demo / sandbox machines. NEVER in production.
DEMO_MODE=0
DUPLICATE_SIMILARITY_THRESHOLD=0.88
# Default fits in 512 MB RAM. Swap to all-mpnet-base-v2 if you have the headroom.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
UPLOAD_DIR=uploads
